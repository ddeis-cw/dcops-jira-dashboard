{
  "name": "dcops-jira-dashboard",
  "version": "1.0.0",
  "description": "DCOPS Jira Dashboard \u2014 CoreWeave Data Center Operations",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "sync": "node src/sync/index.js",
    "migrate": "node src/migrate.js",
