# ── DCOPS Jira Dashboard — Environment Configuration ─────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore by default.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Jira (ticket sync) ────────────────────────────────────────────────────────
# Cloud ID — found at: https://yourorg.atlassian.net/_edge/tenant_info
JIRA_CLOUD_ID=0b202827-7a05-4ef3-94f5-056caea69699

# Your Atlassian account email
JIRA_EMAIL=you@coreweave.com

# Personal API token from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TOKEN=ATATT3xFfGF0...

# ── Jira Assets (employee + server sync) ─────────────────────────────────────
# OAuth2 app credentials — from developer.atlassian.com/console/myapps
# The app needs the read:cmdb scope for Assets access.
ASSETS_CLIENT_ID=kXYbXNkrjqd03cE3fwAnmdka0BzH1i4d
ASSETS_CLIENT_SECRET=ATOAI2nDWhql...

# Assets workspace ID — do not change unless your workspace changes
ASSETS_WORKSPACE=546fdb12-9ec4-464d-833f-61a727f3a5fb
